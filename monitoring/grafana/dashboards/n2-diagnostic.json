{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": [],
      "targetBlank": false,
      "title": "Retour N1",
      "tooltip": "Revenir a la vue operationnelle N1",
      "type": "link",
      "url": "/d/n1overview/api-supervision-n1?var-service=${service}&var-instance=${instance}&var-env=${env}"
    }
  ],
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "targets": [
        {
          "expr": "sum by (status_class) (rate(demo_http_requests_total{service=~\"$service\",instance=~\"$instance\",env=~\"$env\"}[5m]))",
          "legendFormat": "{{status_class}}",
          "refId": "A"
        }
      ],
      "title": "Trafic par classe de statut",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 1,
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "targets": [
        {
          "expr": "topk(5, 1000 * histogram_quantile(0.95, sum by (le, route) (rate(demo_http_request_duration_seconds_bucket{service=~\"$service\",instance=~\"$instance\",env=~\"$env\"}[5m]))))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "title": "Top 5 endpoints par latence p95",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "options": {
        "footer": {
          "show": false
        },
        "showHeader": true
      },
      "targets": [
        {
          "expr": "topk(10, sum by (route) (rate(demo_http_requests_total{service=~\"$service\",instance=~\"$instance\",env=~\"$env\"}[5m])))",
          "format": "table",
          "instant": true,
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "title": "Top 10 endpoints (req/s)",
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "mode": "columns"
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 4,
      "options": {
        "footer": {
          "show": false
        },
        "showHeader": true
      },
      "targets": [
        {
          "expr": "topk(10, 100 * (sum by (route) (rate(demo_http_requests_total{service=~\"$service\",instance=~\"$instance\",status_class=\"5xx\",env=~\"$env\"}[5m])) / clamp_min(sum by (route) (rate(demo_http_requests_total{service=~\"$service\",instance=~\"$instance\",env=~\"$env\"}[5m])), 0.001)))",
          "format": "table",
          "instant": true,
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "title": "Top 10 endpoints par taux 5xx (%)",
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "mode": "columns"
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 16
      },
      "id": 5,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "100 * (1 - (sum(rate(demo_http_requests_total{service=~\"$service\",status_class=\"5xx\",env=~\"$env\"}[24h])) / clamp_min(sum(rate(demo_http_requests_total{service=~\"$service\",env=~\"$env\"}[24h])), 0.001)))",
          "refId": "A"
        }
      ],
      "title": "SLI succes 24h (%)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 16
      },
      "id": 6,
      "targets": [
        {
          "expr": "sum(demo_http_inprogress_requests{service=~\"$service\"})",
          "legendFormat": "in-flight",
          "refId": "A"
        }
      ],
      "title": "Requetes en cours",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 16
      },
      "id": 7,
      "targets": [
        {
          "expr": "sum by (method, route) (rate(demo_http_requests_total{service=~\"$service\",instance=~\"$instance\",env=~\"$env\"}[5m]))",
          "legendFormat": "{{method}} {{route}}",
          "refId": "A"
        }
      ],
      "title": "Requetes par method + route",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "n2",
    "diagnostic",
    "ops"
  ],
  "templating": {
    "list": [
      {
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "definition": "label_values(demo_http_requests_total, service)",
        "includeAll": true,
        "label": "Service",
        "multi": false,
        "name": "service",
        "query": "label_values(demo_http_requests_total, service)",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "definition": "label_values(demo_http_requests_total{service=~\"$service\"}, instance)",
        "includeAll": true,
        "label": "Instance API",
        "multi": false,
        "name": "instance",
        "query": "label_values(demo_http_requests_total{service=~\"$service\"}, instance)",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": "lab",
          "value": "lab"
        },
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "definition": "label_values(up, env)",
        "includeAll": true,
        "label": "Env",
        "multi": false,
        "name": "env",
        "query": "label_values(up, env)",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-2h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "API Diagnostic N2",
  "uid": "n2diagnostic",
  "version": 1,
  "weekStart": ""
}
