{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": [],
      "targetBlank": false,
      "title": "Drilldown N2 Diagnostic",
      "tooltip": "Vue de diagnostic detaillee",
      "type": "link",
      "url": "/d/n2diagnostic/api-diagnostic?var-service=${service}&var-instance=${instance}&var-env=${env}"
    },
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": [],
      "targetBlank": false,
      "title": "Explore Loki (logs)",
      "tooltip": "Corréler un pic erreurs/latence avec les logs",
      "type": "link",
      "url": "/explore?schemaVersion=1&panes={\"loki\":{\"datasource\":\"loki\",\"queries\":[{\"refId\":\"A\",\"expr\":\"{job=\\\"demo-api\\\"}\",\"datasource\":{\"type\":\"loki\",\"uid\":\"loki\"}}]}}"
    }
  ],
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "max(up{job=\"demo-api\",service=~\"$service\",instance=~\"$instance\",env=~\"$env\"})",
          "refId": "A"
        }
      ],
      "title": "Service UP",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 2
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "100 * (sum(rate(demo_http_requests_total{service=~\"$service\",instance=~\"$instance\",status_class=\"5xx\",env=~\"$env\"}[5m])) / clamp_min(sum(rate(demo_http_requests_total{service=~\"$service\",instance=~\"$instance\",env=~\"$env\"}[5m])), 0.001))",
          "refId": "A"
        }
      ],
      "title": "Erreur 5xx (%)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 1,
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 300
              },
              {
                "color": "red",
                "value": 500
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "1000 * histogram_quantile(0.95, sum by (le) (rate(demo_http_request_duration_seconds_bucket{service=~\"$service\",instance=~\"$instance\",env=~\"$env\"}[5m])))",
          "refId": "A"
        }
      ],
      "title": "Latence p95 (ms)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "sum(rate(demo_http_requests_total{service=~\"$service\",instance=~\"$instance\",env=~\"$env\"}[5m]))",
          "refId": "A"
        }
      ],
      "title": "Trafic total (req/s)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 4
      },
      "id": 5,
      "targets": [
        {
          "expr": "sum by (instance) (rate(demo_http_requests_total{service=~\"$service\",instance=~\"$instance\",env=~\"$env\"}[5m]))",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "title": "Trafic par instance (req/s)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 4
      },
      "id": 6,
      "targets": [
        {
          "expr": "100 * (sum(rate(demo_http_requests_total{service=~\"$service\",instance=~\"$instance\",status_class=\"5xx\",env=~\"$env\"}[5m])) / clamp_min(sum(rate(demo_http_requests_total{service=~\"$service\",instance=~\"$instance\",env=~\"$env\"}[5m])), 0.001))",
          "legendFormat": "5xx",
          "refId": "A"
        },
        {
          "expr": "100 * (sum(rate(demo_http_requests_total{service=~\"$service\",instance=~\"$instance\",status_class=\"4xx\",env=~\"$env\"}[5m])) / clamp_min(sum(rate(demo_http_requests_total{service=~\"$service\",instance=~\"$instance\",env=~\"$env\"}[5m])), 0.001))",
          "legendFormat": "4xx",
          "refId": "B"
        }
      ],
      "title": "Taux d'erreurs (%)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 4
      },
      "id": 7,
      "targets": [
        {
          "expr": "100 * (1 - avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\",instance=~\"$node\",env=~\"$env\"}[5m])))",
          "legendFormat": "CPU {{instance}}",
          "refId": "A"
        },
        {
          "expr": "100 * (1 - (node_memory_MemAvailable_bytes{instance=~\"$node\",env=~\"$env\"} / node_memory_MemTotal_bytes{instance=~\"$node\",env=~\"$env\"}))",
          "legendFormat": "RAM {{instance}}",
          "refId": "B"
        }
      ],
      "title": "Saturation CPU / RAM (%)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "id": 8,
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "topk(5, sum by (route) (rate(demo_http_requests_total{service=~\"$service\",instance=~\"$instance\",env=~\"$env\"}[5m])))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "title": "Top 5 endpoints (req/s)",
      "type": "bargauge"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 1,
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "id": 9,
      "targets": [
        {
          "expr": "topk(5, 1000 * histogram_quantile(0.95, sum by (le, route) (rate(demo_http_request_duration_seconds_bucket{service=~\"$service\",instance=~\"$instance\",env=~\"$env\"}[5m]))))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "title": "Top 5 latences p95 par endpoint (ms)",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
